    "### 9.4 Sector fingerprints — radar charts\n",
    "\n",
    "A radar chart makes each sector's unique concern signature visible at a glance. Scores are normalized 0-1 across sectors for fair comparison, so the shape matters more than the size."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d9fe046b",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Normalize each theme across sectors to 0-1 for the radar\n",
    "radar_data = sector_totals[topic_cols].copy().astype(float)\n",
    "for theme in topic_cols:\n",
    "    col = radar_data[theme]\n",
    "    rng = col.max() - col.min()\n",
    "    radar_data[theme] = (col - col.min()) / rng if rng > 0 else 0\n",
    "\n",
    "top_sectors = sector_totals.nlargest(min(6, len(sector_totals)), \"total\").index.tolist()\n",
    "\n",
    "angles = np.linspace(0, 2 * np.pi, len(topic_cols), endpoint=False).tolist()\n",
    "angles += angles[:1]\n",
    "\n",
    "n_plots = len(top_sectors)\n",
    "ncols   = 3\n",
    "nrows   = int(np.ceil(n_plots / ncols))\n",
    "\n",
    "fig, axes = plt.subplots(nrows, ncols,\n",
    "                          figsize=(ncols * 4.2, nrows * 4.2),\n",
    "                          subplot_kw={\"projection\": \"polar\"})\n",
    "axes = np.array(axes).flatten()\n",
    "\n",
